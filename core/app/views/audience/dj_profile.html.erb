<% content_for(:title) { "#{@dj.public_name} | DJMagic.io" } %>

<hgroup>
  <h1><%= @dj.public_name %></h1>
  <p>on DJMagic.io</p>
</hgroup>

<% if @active_shows.any? %>
  <section>
    <h2>Live Now</h2>
    <% @active_shows.each do |show| %>
      <article>
        <h3><a href="<%= audience_show_path(handle: @dj.slug, show_slug: show.slug) %>"><%= show.display_name %></a></h3>
        <p>
          <mark><%= show.show_type.capitalize %></mark>
          &mdash; Started <%= show.started_at.strftime("%l:%M %p") %>
        </p>
        <a href="<%= audience_show_path(handle: @dj.slug, show_slug: show.slug) %>" role="button">Browse Songs &amp; Request</a>
      </article>
    <% end %>
  </section>
<% end %>

<% if @scheduled_shows.any? %>
  <section>
    <h2>Upcoming</h2>
    <% @scheduled_shows.each do |show| %>
      <article>
        <h3><%= show.display_name %></h3>
        <p>
          <mark><%= show.show_type.capitalize %></mark>
          &mdash; <%= show.scheduled_at&.strftime("%b %-d, %l:%M %p") %>
        </p>
      </article>
    <% end %>
  </section>
<% end %>

<% if @active_shows.empty? && @scheduled_shows.empty? %>
  <section>
    <p>No live shows right now. Check back later!</p>
  </section>
<% end %>
