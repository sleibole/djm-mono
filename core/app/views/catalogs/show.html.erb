<h1><%= @catalog.name %></h1>
<p id="song-count"></p>

<section id="search-section" hidden>
  <h2>Search Songs</h2>
  <input type="search" id="search-input" placeholder="Search by title, artist, or version…" autocomplete="off" autofocus>
  <div id="search-results"></div>
</section>

<details id="upload-section" open>
  <summary>Upload CSV</summary>
  <p>Upload a CSV file to replace this catalog's songs. The file must include <code>title</code> and <code>artist</code> columns. See the <a href="<%= doc_path('csv-format') %>">CSV format guide</a> for details.</p>

  <form id="csv-upload-form" enctype="multipart/form-data">
    <label for="csv_file">CSV File</label>
    <input type="file" name="file" id="csv_file" accept=".csv" required>
    <button type="submit" id="upload-btn">Upload</button>
  </form>

  <div id="upload-feedback" role="status" hidden></div>
</details>

<section id="catalog-status-section" hidden>
  <div id="catalog-status"></div>
</section>

<p><a href="<%= catalogs_path %>">Back to catalogs</a></p>

<script>
  (function() {
    const searchSection = document.getElementById("search-section");
    const searchInput = document.getElementById("search-input");
    const searchResults = document.getElementById("search-results");
    const songCountEl = document.getElementById("song-count");
    const form = document.getElementById("csv-upload-form");
    const btn = document.getElementById("upload-btn");
    const feedback = document.getElementById("upload-feedback");
    const statusSection = document.getElementById("catalog-status-section");
    const statusDiv = document.getElementById("catalog-status");
    const uploadSection = document.getElementById("upload-section");
    const uploadUrl = "<%= @songs_upload_url %>";
    const tokenUrl = "<%= upload_token_catalog_path(@catalog) %>";
    const catalogId = "<%= @catalog.id %>";
    const songsAppUrl = "<%= ENV.fetch('SONGS_APP_URL') %>";
    const statusUrl = songsAppUrl + "/catalogs/" + catalogId + "/status";
    const searchUrl = songsAppUrl + "/catalogs/" + catalogId + "/search";

    let debounceTimer = null;

    fetchStatus();

    function fetchStatus() {
      fetch(statusUrl)
        .then(r => r.json())
        .then(data => {
          if (data.active_db_version) {
            searchSection.hidden = false;
            uploadSection.removeAttribute("open");
            if (data.song_count != null) {
              songCountEl.textContent = data.song_count.toLocaleString() + " songs";
            }
          }

          if (data.status === "processing" || data.status === "pending") {
            pollStatus();
          } else if (data.status === "failed") {
            statusSection.hidden = false;
            statusDiv.className = "flash alert";
            let msg = "Latest upload failed.";
            if (data.errors && data.errors.length) {
              msg += " " + data.errors.map(e => e.detail || e).join("; ");
            }
            statusDiv.textContent = msg;
          }
        })
        .catch(() => {});
    }

    // --- Search ---

    searchInput.addEventListener("input", function() {
      clearTimeout(debounceTimer);
      const query = searchInput.value.trim();

      if (!query) {
        searchResults.innerHTML = "";
        return;
      }

      debounceTimer = setTimeout(() => performSearch(query), 300);
    });

    async function performSearch(query) {
      const loadingTimer = setTimeout(() => {
        searchResults.innerHTML = '<p aria-busy="true">Searching…</p>';
      }, 500);

      try {
        const response = await fetch(searchUrl + "?q=" + encodeURIComponent(query) + "&limit=50");
        const data = await response.json();
        clearTimeout(loadingTimer);

        if (!response.ok) {
          searchResults.innerHTML = '<p class="flash alert">' + (data.error || "Search failed.") + '</p>';
          return;
        }

        if (data.songs.length === 0) {
          searchResults.innerHTML = "<p>No songs found.</p>";
          return;
        }

        renderResults(data);
      } catch (err) {
        clearTimeout(loadingTimer);
        searchResults.innerHTML = '<p class="flash alert">Could not reach the songs service.</p>';
      }
    }

    function renderResults(data) {
      const hasVersion = data.songs.some(s => s.version);
      const hasAlbum = data.songs.some(s => s.album);

      let html = '<p><small>' + data.total + ' result' + (data.total !== 1 ? 's' : '') + '</small></p>';
      html += '<table class="striped" role="grid"><thead><tr>';
      html += '<th>Title</th><th>Artist</th>';
      if (hasVersion) html += '<th>Version</th>';
      if (hasAlbum) html += '<th>Album</th>';
      html += '</tr></thead><tbody>';

      data.songs.forEach(function(song) {
        html += '<tr>';
        html += '<td>' + escapeHtml(song.title) + '</td>';
        html += '<td>' + escapeHtml(song.artist) + '</td>';
        if (hasVersion) html += '<td>' + escapeHtml(song.version || '') + '</td>';
        if (hasAlbum) html += '<td>' + escapeHtml(song.album || '') + '</td>';
        html += '</tr>';
      });

      html += '</tbody></table>';
      searchResults.innerHTML = html;
    }

    function escapeHtml(text) {
      const d = document.createElement("div");
      d.textContent = text;
      return d.innerHTML;
    }

    // --- Upload ---

    function showFeedback(message, type) {
      feedback.hidden = false;
      feedback.className = "flash " + type;
      feedback.textContent = message;
    }

    form.addEventListener("submit", async function(e) {
      e.preventDefault();

      const fileInput = document.getElementById("csv_file");
      if (!fileInput.files.length) return;

      btn.disabled = true;
      btn.setAttribute("aria-busy", "true");
      btn.textContent = "Uploading…";
      feedback.hidden = true;

      try {
        const tokenResponse = await fetch(tokenUrl, {
          method: "POST",
          headers: {
            "X-CSRF-Token": document.querySelector('meta[name="csrf-token"]').content
          }
        });

        if (!tokenResponse.ok) {
          showFeedback("Could not get upload authorization. Please refresh and try again.", "alert");
          return;
        }

        const { token } = await tokenResponse.json();

        const formData = new FormData();
        formData.append("file", fileInput.files[0]);
        formData.append("token", token);

        const response = await fetch(uploadUrl, {
          method: "POST",
          body: formData
        });

        const data = await response.json();

        if (response.ok) {
          showFeedback("Upload accepted. Processing your catalog…", "notice");
          pollStatus();
        } else {
          showFeedback(data.error || "Upload failed.", "alert");
        }
      } catch (err) {
        showFeedback("Could not reach the songs service. Please try again.", "alert");
      } finally {
        btn.disabled = false;
        btn.removeAttribute("aria-busy");
        btn.textContent = "Upload";
      }
    });

    // --- Status polling ---

    function pollStatus() {
      statusSection.hidden = false;
      statusDiv.textContent = "Processing…";
      statusDiv.setAttribute("aria-busy", "true");

      let attempts = 0;
      const maxAttempts = 60;

      const interval = setInterval(async function() {
        attempts++;
        try {
          const response = await fetch(statusUrl);
          const data = await response.json();

          if (data.status === "ready") {
            clearInterval(interval);
            feedback.hidden = true;
            statusDiv.removeAttribute("aria-busy");
            statusDiv.className = "flash notice";
            statusDiv.textContent = "Catalog is ready!";
            searchSection.hidden = false;
            searchInput.value = "";
            searchResults.innerHTML = "";
            if (data.song_count != null) {
              songCountEl.textContent = data.song_count.toLocaleString() + " songs";
            }
          } else if (data.status === "failed") {
            clearInterval(interval);
            feedback.hidden = true;
            statusDiv.removeAttribute("aria-busy");
            statusDiv.className = "flash alert";
            let msg = data.active_db_version ? "Latest upload failed." : "Processing failed.";
            if (data.errors && data.errors.length) {
              msg += " " + data.errors.map(e => e.detail || e).join("; ");
            }
            statusDiv.textContent = msg;
            if (data.active_db_version) {
              searchSection.hidden = false;
            }
          } else {
            statusDiv.textContent = "Processing… (status: " + data.status + ")";
          }
        } catch (err) {
          statusDiv.textContent = "Checking status…";
        }

        if (attempts >= maxAttempts) {
          clearInterval(interval);
          statusDiv.removeAttribute("aria-busy");
          statusDiv.textContent = "Status check timed out. Refresh the page to check again.";
        }
      }, 2000);
    }
  })();
</script>
