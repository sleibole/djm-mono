<h1><%= @catalog.name %></h1>
<p id="song-count"></p>

<section id="search-section" hidden>
  <h2>Search Songs</h2>
  <input type="search" id="search-input" placeholder="Search by title, artist, or version…" autocomplete="off" autofocus>
  <div id="search-results"></div>
</section>

<details id="upload-section" class="section-panel" open>
  <summary>Upload CSV</summary>
  <div id="upload-feedback" role="status" hidden></div>
  <p>Upload a CSV file to replace this catalog's songs. The file must include <code>title</code> and <code>artist</code> columns. See the <a href="<%= doc_path('csv-format') %>">CSV format guide</a> for details.</p>

  <form id="csv-upload-form" enctype="multipart/form-data">
    <label for="csv_file"><i class="fa-solid fa-file-arrow-up"></i> CSV File</label>
    <input type="file" name="file" id="csv_file" accept=".csv" required>
    <button type="submit" id="upload-btn">Upload</button>
  </form>
</details>

<details id="settings-section" class="section-panel">
  <summary>Settings</summary>
  <%= form_with model: @catalog, method: :patch do |f| %>
    <label for="variant_display">Show selector for song variants</label>
    <%= f.select :variant_display,
      [["None", "none"], ["Version (Original, Acoustic, Key +2…)", "version"], ["ID (disc/track number)", "id"]],
      { selected: @catalog.variant_display },
      { id: "variant_display" } %>
    <small>Controls whether singers see a dropdown to pick a specific version or disc/track ID.</small>
    <%= f.submit "Save", class: "secondary" %>
  <% end %>
</details>

<p><a href="<%= catalogs_path %>">Back to catalogs</a></p>

<script>
  (function() {
    const searchSection = document.getElementById("search-section");
    const searchInput = document.getElementById("search-input");
    const searchResults = document.getElementById("search-results");
    const songCountEl = document.getElementById("song-count");
    const form = document.getElementById("csv-upload-form");
    const btn = document.getElementById("upload-btn");
    const feedback = document.getElementById("upload-feedback");
    const uploadSection = document.getElementById("upload-section");
    const settingsSection = document.getElementById("settings-section");
    const uploadUrl = "<%= @songs_upload_url %>";
    const tokenUrl = "<%= upload_token_catalog_path(@catalog) %>";
    const catalogId = "<%= @catalog.id %>";
    const songsAppUrl = "<%= @songs_app_url %>";
    const statusUrl = songsAppUrl + "/catalogs/" + catalogId + "/status";
    const searchUrl = songsAppUrl + "/catalogs/" + catalogId + "/search";
    const variantDisplay = "<%= @catalog.variant_display %>";

    let debounceTimer = null;

    fetchStatus();

    function fetchStatus() {
      fetch(statusUrl)
        .then(r => r.json())
        .then(data => {
          if (data.active_db_version) {
            searchSection.hidden = false;
            uploadSection.removeAttribute("open");
            if (data.song_count != null) {
              songCountEl.textContent = data.song_count.toLocaleString() + " songs";
            }
          } else {
            settingsSection.setAttribute("open", "");
          }

          if (data.status === "processing" || data.status === "pending") {
            pollStatus();
          } else if (data.status === "failed") {
            uploadSection.setAttribute("open", "");
            let msg = "Latest upload failed.";
            if (data.errors && data.errors.length) {
              msg += " " + data.errors.map(e => e.detail || e).join("; ");
            }
            showFeedback(msg, "alert");
          }
        })
        .catch(() => {});
    }

    // --- Search ---

    searchInput.addEventListener("input", function() {
      clearTimeout(debounceTimer);
      const query = searchInput.value.trim();

      if (!query) {
        searchResults.innerHTML = "";
        return;
      }

      debounceTimer = setTimeout(() => performSearch(query), 300);
    });

    async function performSearch(query) {
      const loadingTimer = setTimeout(() => {
        searchResults.innerHTML = '<p aria-busy="true">Searching…</p>';
      }, 500);

      try {
        const response = await fetch(searchUrl + "?q=" + encodeURIComponent(query) + "&limit=50");
        const data = await response.json();
        clearTimeout(loadingTimer);

        if (!response.ok) {
          searchResults.innerHTML = '<p class="flash alert">' + (data.error || "Search failed.") + '</p>';
          return;
        }

        if (data.songs.length === 0) {
          searchResults.innerHTML = "<p>No songs found.</p>";
          return;
        }

        renderResults(data);
      } catch (err) {
        clearTimeout(loadingTimer);
        searchResults.innerHTML = '<p class="flash alert">Could not reach the songs service.</p>';
      }
    }

    function renderResults(data) {
      const showVersionCol = variantDisplay === "version" && data.songs.some(s => s.versions && s.versions.length > 0);
      const showIdCol = variantDisplay === "id" && data.songs.some(s => s.external_ids && s.external_ids.length > 0);
      const hasAlbum = data.songs.some(s => s.album);

      let html = '<p><small>' + data.total + ' result' + (data.total !== 1 ? 's' : '') + '</small></p>';
      html += '<table class="striped" role="grid"><thead><tr>';
      html += '<th>Title</th><th>Artist</th>';
      if (showVersionCol) html += '<th>Version</th>';
      if (showIdCol) html += '<th>ID</th>';
      if (hasAlbum) html += '<th>Album</th>';
      html += '</tr></thead><tbody>';

      data.songs.forEach(function(song) {
        html += '<tr>';
        html += '<td>' + escapeHtml(song.title) + '</td>';
        html += '<td>' + escapeHtml(song.artist) + '</td>';
        if (showVersionCol) html += '<td>' + renderVariantCell(song.versions) + '</td>';
        if (showIdCol) html += '<td>' + renderVariantCell(song.external_ids) + '</td>';
        if (hasAlbum) html += '<td>' + escapeHtml(song.album || '') + '</td>';
        html += '</tr>';
      });

      html += '</tbody></table>';
      searchResults.innerHTML = html;
    }

    function renderVariantCell(items) {
      if (!items || items.length === 0) return '';
      if (items.length === 1) return escapeHtml(items[0]);

      let html = '<select>';
      items.forEach(function(item) {
        html += '<option>' + escapeHtml(item) + '</option>';
      });
      html += '</select>';
      return html;
    }

    function escapeHtml(text) {
      const d = document.createElement("div");
      d.textContent = text;
      return d.innerHTML;
    }

    // --- Upload ---

    function showFeedback(message, type) {
      feedback.hidden = false;
      feedback.className = "flash " + type;
      feedback.textContent = message;
    }

    form.addEventListener("submit", async function(e) {
      e.preventDefault();

      const fileInput = document.getElementById("csv_file");
      if (!fileInput.files.length) return;

      btn.disabled = true;
      btn.setAttribute("aria-busy", "true");
      btn.textContent = "Uploading…";
      feedback.hidden = true;

      try {
        const tokenResponse = await fetch(tokenUrl, {
          method: "POST",
          headers: {
            "X-CSRF-Token": document.querySelector('meta[name="csrf-token"]').content
          }
        });

        if (!tokenResponse.ok) {
          showFeedback("Could not get upload authorization. Please refresh and try again.", "alert");
          return;
        }

        const { token } = await tokenResponse.json();

        const formData = new FormData();
        formData.append("file", fileInput.files[0]);
        formData.append("token", token);

        const response = await fetch(uploadUrl, {
          method: "POST",
          body: formData
        });

        const data = await response.json();

        if (response.ok) {
          showFeedback("Upload accepted. Processing your catalog…", "notice");
          pollStatus();
        } else {
          showFeedback(data.error || "Upload failed.", "alert");
        }
      } catch (err) {
        showFeedback("Could not reach the songs service. Please try again.", "alert");
      } finally {
        btn.disabled = false;
        btn.removeAttribute("aria-busy");
        btn.textContent = "Upload";
      }
    });

    // --- Status polling ---

    function pollStatus() {
      uploadSection.setAttribute("open", "");
      showFeedback("Processing…", "notice");
      feedback.setAttribute("aria-busy", "true");
      uploadSection.scrollIntoView({ behavior: "smooth", block: "nearest" });

      let attempts = 0;
      const maxAttempts = 60;

      const interval = setInterval(async function() {
        attempts++;
        try {
          const response = await fetch(statusUrl);
          const data = await response.json();

          if (data.status === "ready") {
            clearInterval(interval);
            feedback.removeAttribute("aria-busy");
            showFeedback("Catalog is ready!", "notice");
            searchSection.hidden = false;
            searchInput.value = "";
            searchResults.innerHTML = "";
            if (data.song_count != null) {
              songCountEl.textContent = data.song_count.toLocaleString() + " songs";
            }
            setTimeout(() => {
              uploadSection.removeAttribute("open");
              feedback.hidden = true;
            }, 3000);
          } else if (data.status === "failed") {
            clearInterval(interval);
            feedback.removeAttribute("aria-busy");
            let msg = data.active_db_version ? "Latest upload failed." : "Processing failed.";
            if (data.errors && data.errors.length) {
              msg += " " + data.errors.map(e => e.detail || e).join("; ");
            }
            showFeedback(msg, "alert");
            if (data.active_db_version) {
              searchSection.hidden = false;
            }
          } else {
            showFeedback("Processing…", "notice");
            feedback.setAttribute("aria-busy", "true");
          }
        } catch (err) {
          showFeedback("Checking status…", "notice");
          feedback.setAttribute("aria-busy", "true");
        }

        if (attempts >= maxAttempts) {
          clearInterval(interval);
          feedback.removeAttribute("aria-busy");
          showFeedback("Status check timed out. Refresh the page to check again.", "alert");
        }
      }, 2000);
    }
  })();
</script>
