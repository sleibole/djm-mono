<h1>My Catalogs</h1>

<p><a href="<%= new_catalog_path %>" role="button">New Catalog</a></p>

<% if @catalogs.any? %>
  <table class="striped">
    <thead>
      <tr>
        <th>Name</th>
        <th>Created</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      <% @catalogs.each do |catalog| %>
        <tr>
          <td><a href="<%= catalog_path(catalog) %>"><%= catalog.name %></a></td>
          <td><%= catalog.created_at.strftime("%b %d, %Y") %></td>
          <td><a href="<%= catalog_path(catalog) %>">Manage</a></td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <p>No catalogs yet. Create one to get started.</p>
<% end %>
