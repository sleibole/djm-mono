<h1>New Catalog</h1>

<%= form_with model: Catalog.new, url: catalogs_path do |f| %>
  <% if f.object.errors.any? %>
    <p role="alert" class="flash alert">
      <%= f.object.errors.full_messages.to_sentence %>
    </p>
  <% end %>

  <label for="catalog_name"><i class="fa-solid fa-folder-open"></i> Name</label>
  <%= f.text_field :name, placeholder: "e.g. Karaoke Night, Wedding Set", required: true, autofocus: true %>

  <%= f.submit "Create Catalog" %>
<% end %>

<p><a href="<%= catalogs_path %>">Back to catalogs</a></p>
