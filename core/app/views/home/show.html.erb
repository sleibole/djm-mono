<%# ── Logo ── %>
<section style="text-align: center; padding: 3rem 1rem;">
  <%= image_tag('brand_icons/dark/dark_192.png', alt: 'DJMagic.io', style: 'border-radius: 12px;') %>
</section>

<%# ── Landing Footer ── %>
<footer class="landing-footer">
  <p>Join our community</p>
  <p>
    <a href="https://www.reddit.com/r/djmagicio/" target="_blank" rel="noopener noreferrer" class="reddit-link">
      <i class="fa-brands fa-reddit"></i>
      <span>r/djmagicio</span>
    </a>
  </p>
</footer>

<script>
  document.addEventListener('DOMContentLoaded', function () {
    var img = document.getElementById('paper-slip-image');
    var tiredHeading = document.getElementById('tired-heading');
    var usTooHeading = document.getElementById('us-too-heading');

    if (!img || !tiredHeading || !usTooHeading) return;

    function playAnimation(element, callback) {
      element.classList.remove('text-grow-shrink');
      void element.offsetWidth;
      element.classList.add('text-grow-shrink');

      element.addEventListener('animationend', function handler(event) {
        if (event.target !== element) return;
        element.removeEventListener('animationend', handler);
        if (typeof callback === 'function') callback();
      });
    }

    function rotatePaper(callback) {
      function handleTransition(event) {
        if (event.propertyName !== 'transform') return;
        img.removeEventListener('transitionend', handleTransition);
        if (typeof callback === 'function') callback();
      }

      img.addEventListener('transitionend', handleTransition);
      img.classList.add('paper-rotated');
    }

    function startSequence() {
      setTimeout(function () {
        playAnimation(tiredHeading, function () {
          rotatePaper(function () {
            playAnimation(usTooHeading);
          });
        });
      }, 1000);
    }

    if (img.complete) {
      startSequence();
    } else {
      img.addEventListener('load', startSequence, { once: true });
    }
  });
</script>

<% end %>
