<h1>Account</h1>

<section data-controller="theme">
  <h2>Appearance</h2>
  <p><small>This setting is saved to this device only and won't sync across your other devices. By default, we match your operating system's light or dark mode preference.</small></p>
  <fieldset>
    <label>
      <input type="radio" name="theme" data-action="change->theme#setSystem" data-theme-target="systemRadio">
      System default
    </label>
    <label>
      <input type="radio" name="theme" data-action="change->theme#setLight" data-theme-target="lightRadio">
      Light
    </label>
    <label>
      <input type="radio" name="theme" data-action="change->theme#setDark" data-theme-target="darkRadio">
      Dark
    </label>
  </fieldset>
</section>

<section>
  <h2>Display Name</h2>
  <p>This is the name shown to your audience. If not set, your handle will be used instead.</p>

  <%= form_with url: account_display_name_path, method: :patch do |f| %>
    <label for="display_name">Display Name</label>
    <input type="text" name="display_name" id="display_name" value="<%= current_user.display_name %>"
           placeholder="e.g. DJ Mike" maxlength="50">
    <%= f.submit "Save Display Name", class: "secondary" %>
  <% end %>
</section>

<section>
  <h2>Your Handle</h2>
  <% if current_user.slug.present? %>
    <p>Your public URL: <strong>djmagic.io/dj/<%= current_user.slug %></strong></p>
  <% else %>
    <p>Set a handle to get a public profile page and shareable links for your shows.</p>
  <% end %>

  <%= form_with url: account_slug_path, method: :patch do |f| %>
    <label for="slug">Handle</label>
    <input type="text" name="slug" id="slug" value="<%= current_user.slug %>"
           placeholder="e.g. djmike" required minlength="3" maxlength="30"
           pattern="[a-z0-9][a-z0-9\-]*[a-z0-9]">
    <small>Lowercase letters, numbers, and hyphens. 3&ndash;30 characters.</small>
    <%= f.submit "Save Handle", class: "secondary" %>
  <% end %>
</section>

<section>
  <h2>Email</h2>
  <p><%= current_user.email %></p>
</section>

<section>
  <h2>Password</h2>

  <% if current_user.has_password? %>
    <p>You have a password set. You can change it or remove it to use magic links only.</p>

    <%= form_with url: account_password_path, method: :patch do |f| %>
      <label for="password">New Password</label>
      <%= f.password_field :password, id: "password", required: true, minlength: 8 %>

      <label for="password_confirmation">Confirm Password</label>
      <%= f.password_field :password_confirmation, id: "password_confirmation", required: true, minlength: 8 %>

      <%= f.submit "Change Password", class: "secondary" %>
    <% end %>

    <%= button_to "Remove Password", account_password_path, method: :delete, class: "btn-danger outline", data: { turbo_confirm: "Are you sure? You'll use magic links to log in." } %>
  <% else %>
    <p>No password set. You log in with magic links. You can optionally set a password.</p>

    <%= form_with url: account_password_path, method: :patch do |f| %>
      <label for="password">Password</label>
      <%= f.password_field :password, id: "password", required: true, minlength: 8 %>

      <label for="password_confirmation">Confirm Password</label>
      <%= f.password_field :password_confirmation, id: "password_confirmation", required: true, minlength: 8 %>

      <%= f.submit "Set Password", class: "secondary" %>
    <% end %>
  <% end %>
</section>
