<header>
  <h1><%= @show.catalog.name %></h1>
  <p>
    <% if @show.active? %>
      <mark>Live</mark> &mdash; <%= @show.show_type.capitalize %> &mdash; Started <%= @show.started_at.strftime("%l:%M %p") %>
    <% else %>
      <%= @show.show_type.capitalize %> &mdash; Ended <%= @show.ended_at&.strftime("%b %-d, %l:%M %p") %>
    <% end %>
  </p>
</header>

<% if @show.active? && current_user.slug.present? %>
  <%# --- Share / QR Codes --- %>
  <section id="share-section">
    <details>
      <summary>Share with your audience</summary>
      <div style="display: flex; gap: 2rem; flex-wrap: wrap;">
        <div>
          <h4>This Show</h4>
          <%= raw RQRCode::QRCode.new(@show.public_url).as_svg(
            module_size: 4,
            standalone: true,
            use_path: true,
            viewbox: true,
            svg_attributes: { style: "max-width: 200px; width: 100%;" }
          ) %>
          <p><small><code id="show-url"><%= @show.public_url %></code></small></p>
          <button type="button" class="outline secondary" onclick="navigator.clipboard.writeText(document.getElementById('show-url').textContent)">Copy show link</button>
        </div>
        <div>
          <h4>Your Profile</h4>
          <%= raw RQRCode::QRCode.new(@show.dj_profile_url).as_svg(
            module_size: 4,
            standalone: true,
            use_path: true,
            viewbox: true,
            svg_attributes: { style: "max-width: 200px; width: 100%;" }
          ) %>
          <p><small><code id="profile-url"><%= @show.dj_profile_url %></code></small></p>
          <button type="button" class="outline secondary" onclick="navigator.clipboard.writeText(document.getElementById('profile-url').textContent)">Copy profile link</button>
        </div>
      </div>
    </details>
  </section>
<% elsif @show.active? && current_user.slug.blank? %>
  <section>
    <p>
      <a href="<%= account_path %>">Set your handle</a> to share a QR code and public link with your audience.
    </p>
  </section>
<% end %>

<% if @show.active? %>
  <%# --- Pending Requests (polls for updates) --- %>
  <%= turbo_frame_tag "pending-requests", data: { controller: "poll", poll_interval_value: 10000, poll_src_value: show_path(@show) } do %>
    <% if @show.approval_required? && @pending.any? %>
      <section id="pending-requests">
        <h2>Pending Requests <small>(<%= @pending.count %>)</small></h2>
        <table class="striped" role="grid">
          <thead>
            <tr>
              <th><%= @show.participant_label %></th>
              <th>Song</th>
              <th>Submitted</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% @pending.each do |entry| %>
              <tr>
                <td><%= entry.participant.name %></td>
                <td>
                  <%= entry.song_title %> &mdash; <%= entry.song_artist %>
                  <% if entry.song_version.present? %>
                    <br><small><%= entry.song_version %></small>
                  <% end %>
                </td>
                <td><small><%= entry.created_at.strftime("%l:%M %p") %></small></td>
                <td>
                  <div style="display: flex; gap: 0.25rem;">
                    <%= button_to approve_show_queue_entry_path(@show, entry), method: :patch, title: "Approve", style: "background: #2e7d32; border-color: #2e7d32; padding: 0; width: 2rem; height: 2rem; color: #fff; font-size: 1rem; line-height: 1; margin: 0;" do %>✓<% end %>
                    <button type="button" title="Reject" style="background: #c62828; border-color: #c62828; padding: 0; width: 2rem; height: 2rem; color: #fff; font-size: 1rem; line-height: 1; margin: 0;" onclick="document.getElementById('reject-dialog-<%= entry.id %>').showModal()">✕</button>
                  </div>
                  <dialog id="reject-dialog-<%= entry.id %>">
                    <article>
                      <h3>Reject request from <%= entry.participant.name %>?</h3>
                      <p><strong><%= entry.song_title %></strong> &mdash; <%= entry.song_artist %></p>
                      <%= form_with url: reject_show_queue_entry_path(@show, entry), method: :patch do %>
                        <textarea name="rejection_reason" placeholder="Reason (optional)" rows="2"></textarea>
                        <div role="group">
                          <button type="submit" class="btn-danger">Reject</button>
                          <button type="button" class="secondary" onclick="document.getElementById('reject-dialog-<%= entry.id %>').close()">Cancel</button>
                        </div>
                      <% end %>
                    </article>
                  </dialog>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </section>
    <% end %>
  <% end %>

  <%# --- Now Playing --- %>
  <section id="now-playing">
    <h2>Now Playing</h2>
    <% if @now_playing %>
      <article>
        <p>
          <strong><%= @now_playing.participant.name %></strong> &mdash;
          <%= @now_playing.song_title %> by <%= @now_playing.song_artist %>
          <% if @now_playing.song_version.present? %>
            (<%= @now_playing.song_version %>)
          <% end %>
        </p>
        <div role="group">
          <%= button_to "Done", mark_done_show_queue_entry_path(@show, @now_playing), method: :patch %>
          <%= button_to "Skip", skip_show_queue_entry_path(@show, @now_playing), method: :patch, class: "secondary" %>
        </div>
      </article>
    <% else %>
      <p><small>No one is performing right now.</small></p>
    <% end %>
  </section>

  <%# --- Up Next / Queue --- %>
  <section id="queue">
    <h2>Queue <small>(<%= @waiting.count %>)</small></h2>
    <% if @waiting.any? %>
      <table class="striped" role="grid">
        <thead>
          <tr>
            <th>#</th>
            <th><%= @show.participant_label %></th>
            <th>Song</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% @waiting.each_with_index do |entry, idx| %>
            <tr>
              <td><%= idx + 1 %></td>
              <td><%= entry.participant.name %></td>
              <td>
                <%= entry.song_title %> &mdash; <%= entry.song_artist %>
                <% if entry.song_version.present? %>
                  <br><small><%= entry.song_version %></small>
                <% end %>
              </td>
              <td>
                <div role="group">
                  <%= button_to "▶", now_playing_show_queue_entry_path(@show, entry), method: :patch, class: "outline", title: "Start" %>
                  <% if idx > 0 %>
                    <%= button_to "↑", move_show_queue_entry_path(@show, entry, position: entry.position - 1), method: :patch, class: "outline secondary", title: "Move up" %>
                  <% else %>
                    <%= button_to "↑", "#", disabled: true, class: "outline secondary queue-hidden-btn", title: "Move up" %>
                  <% end %>
                  <% if idx < @waiting.count - 1 %>
                    <%= button_to "↓", move_show_queue_entry_path(@show, entry, position: entry.position + 1), method: :patch, class: "outline secondary", title: "Move down" %>
                  <% else %>
                    <%= button_to "↓", "#", disabled: true, class: "outline secondary queue-hidden-btn", title: "Move down" %>
                  <% end %>
                  <%= button_to "✕", show_queue_entry_path(@show, entry), method: :delete, class: "btn-danger outline", title: "Remove", data: { turbo_confirm: "Remove #{entry.participant.name} from the queue?" } %>
                </div>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <p><small>The queue is empty. Add someone below.</small></p>
    <% end %>
  </section>

  <%# --- Add to Queue --- %>
  <section id="add-to-queue">
    <h2>Add to Queue</h2>
    <%= form_with url: show_queue_entries_path(@show), method: :post, id: "add-queue-form" do %>
      <fieldset>
        <label for="participant_name"><%= @show.participant_label %></label>
        <input type="text" name="participant_name" id="participant_name" placeholder="<%= @show.participant_label %>'s name" required autocomplete="off" list="participant-suggestions">
        <input type="hidden" name="participant_id" id="participant_id">
        <datalist id="participant-suggestions"></datalist>
      </fieldset>

      <fieldset>
        <label>Song</label>
        <div role="group" class="tab-group">
          <button type="button" id="mode-search" class="active" onclick="toggleSongMode('search')">Search Catalog</button>
          <button type="button" id="mode-manual" onclick="toggleSongMode('manual')">Enter Manually</button>
        </div>

        <div id="song-search-mode">
          <input type="search" id="song-search-input" placeholder="Search by title or artist…" autocomplete="off">
          <div id="song-search-results"></div>
        </div>

        <div id="song-manual-mode" hidden>
          <input type="text" name="song_title" id="manual-song-title" placeholder="Song title">
          <input type="text" name="song_artist" id="manual-song-artist" placeholder="Artist">
        </div>

        <div id="song-selected" hidden>
          <article>
            <p>
              <strong id="selected-song-title"></strong> &mdash; <span id="selected-song-artist"></span>
              <span id="selected-song-version"></span>
            </p>
            <button type="button" class="outline secondary" onclick="clearSongSelection()">Change</button>
          </article>
          <input type="hidden" name="song_title" id="hidden-song-title">
          <input type="hidden" name="song_artist" id="hidden-song-artist">
          <input type="hidden" name="song_version" id="hidden-song-version">
          <input type="hidden" name="song_external_id" id="hidden-song-external-id">
        </div>
      </fieldset>

      <button type="submit" id="add-queue-btn">Add to Queue</button>
    <% end %>
  </section>
<% end %>

<% if @completed.any? %>
  <details id="completed-songs">
    <summary>Completed (<%= @completed.count %>)</summary>
    <table class="striped" role="grid">
      <thead>
        <tr>
          <th><%= @show.participant_label %></th>
          <th>Song</th>
          <th>Time</th>
          <th>Status</th>
        </tr>
      </thead>
      <tbody>
        <% @completed.each do |entry| %>
          <tr>
            <td><%= entry.participant.name %></td>
            <td><%= entry.song_title %> &mdash; <%= entry.song_artist %></td>
            <td><%= entry.performed_at&.strftime("%l:%M %p") %></td>
            <td><%= entry.status.capitalize %></td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </details>
<% end %>

<% if @show.active? %>
  <hr>
  <details>
    <summary>Show Settings</summary>
    <%= form_with model: @show, method: :patch do |f| %>
      <label for="show_show_type">Show Type</label>
      <%= f.select :show_type, [["Karaoke", "karaoke"], ["DJ", "dj"]] %>

      <label for="show_rotation_style">Rotation Style</label>
      <%= f.select :rotation_style, [["Standard Rotation", "standard"]] %>

      <label for="show_max_songs_per_singer">Max Songs per <%= @show.participant_label %></label>
      <%= f.number_field :max_songs_per_singer, min: 1, placeholder: "Unlimited" %>
      <small>Leave blank for unlimited.</small>

      <hr>

      <h4>Audience Settings</h4>

      <label>
        <%= f.check_box :approval_required %>
        Require approval for audience requests
      </label>
      <small>When enabled, audience song requests must be approved before entering the queue.</small>

      <label>
        <%= f.check_box :manual_entry_enabled %>
        Allow manual song entry
      </label>
      <small>Let audience members request songs not in your catalog.</small>

      <label for="show_slug">Show URL slug</label>
      <%= f.text_field :slug, placeholder: "e.g. tuesday-karaoke" %>
      <% if current_user.slug.present? %>
        <small>Public URL: djmagic.io/dj/<%= current_user.slug %>/shows/<%= @show.slug %></small>
      <% end %>

      <%= f.submit "Save Settings", class: "secondary" %>
    <% end %>
  </details>

  <hr>
  <%= button_to "End Show", end_show_show_path(@show), method: :patch, class: "btn-danger outline", data: { turbo_confirm: "End this show? The queue will be closed." } %>
<% end %>

<p><a href="<%= shows_path %>">Back to shows</a></p>

<script>
  (function() {
    const searchUrl = "<%= @songs_app_url %>/catalogs/<%= @show.catalog_id %>/search";
    const participantInput = document.getElementById("participant_name");
    const participantIdInput = document.getElementById("participant_id");
    const datalist = document.getElementById("participant-suggestions");
    const songSearchInput = document.getElementById("song-search-input");
    const songResults = document.getElementById("song-search-results");

    let participantTimer = null;
    let songTimer = null;

    // --- Participant autocomplete ---
    participantInput.addEventListener("input", function() {
      clearTimeout(participantTimer);
      participantIdInput.value = "";
      const q = participantInput.value.trim();
      if (!q) { datalist.innerHTML = ""; return; }

      participantTimer = setTimeout(async () => {
        try {
          const resp = await fetch("/participants/autocomplete?q=" + encodeURIComponent(q));
          const participants = await resp.json();
          datalist.innerHTML = participants.map(p =>
            '<option value="' + escapeAttr(p.name) + '" data-id="' + p.id + '">'
          ).join("");
        } catch(e) {}
      }, 200);
    });

    participantInput.addEventListener("change", function() {
      const opts = datalist.querySelectorAll("option");
      for (const opt of opts) {
        if (opt.value === participantInput.value) {
          participantIdInput.value = opt.dataset.id;
          break;
        }
      }
    });

    // --- Song mode toggle ---
    window.toggleSongMode = function(mode) {
      const searchMode = document.getElementById("song-search-mode");
      const manualMode = document.getElementById("song-manual-mode");
      const selected = document.getElementById("song-selected");
      const searchBtn = document.getElementById("mode-search");
      const manualBtn = document.getElementById("mode-manual");

      selected.hidden = true;

      if (mode === "search") {
        searchMode.hidden = false;
        manualMode.hidden = true;
        searchBtn.className = "active";
        manualBtn.className = "";
        document.getElementById("manual-song-title").removeAttribute("name");
        document.getElementById("manual-song-artist").removeAttribute("name");
      } else {
        searchMode.hidden = true;
        manualMode.hidden = false;
        searchBtn.className = "";
        manualBtn.className = "active";
        document.getElementById("manual-song-title").setAttribute("name", "song_title");
        document.getElementById("manual-song-artist").setAttribute("name", "song_artist");
        clearHiddenSongFields();
      }
    };

    // --- Song search ---
    if (songSearchInput) {
      songSearchInput.addEventListener("input", function() {
        clearTimeout(songTimer);
        const q = songSearchInput.value.trim();
        if (!q) { songResults.innerHTML = ""; return; }

        songTimer = setTimeout(async () => {
          try {
            const resp = await fetch(searchUrl + "?q=" + encodeURIComponent(q) + "&limit=10");
            const data = await resp.json();
            if (data.songs.length === 0) {
              songResults.innerHTML = "<p><small>No songs found.</small></p>";
              return;
            }
            let html = '<table class="striped" role="grid"><tbody>';
            data.songs.forEach(function(song) {
              html += '<tr style="cursor:pointer" onclick=\'selectSong(' + JSON.stringify(song).replace(/'/g, "&#39;") + ')\'>';
              html += '<td>' + escapeHtml(song.title) + '</td>';
              html += '<td>' + escapeHtml(song.artist) + '</td>';
              if (song.version) html += '<td><small>' + escapeHtml(song.version) + '</small></td>';
              html += '</tr>';
            });
            html += '</tbody></table>';
            songResults.innerHTML = html;
          } catch(e) {
            songResults.innerHTML = '<p><small>Search unavailable.</small></p>';
          }
        }, 300);
      });
    }

    window.selectSong = function(song) {
      document.getElementById("hidden-song-title").value = song.title;
      document.getElementById("hidden-song-artist").value = song.artist;
      document.getElementById("hidden-song-version").value = song.version || "";
      document.getElementById("hidden-song-external-id").value = song.external_id || "";

      document.getElementById("selected-song-title").textContent = song.title;
      document.getElementById("selected-song-artist").textContent = song.artist;
      const versionSpan = document.getElementById("selected-song-version");
      versionSpan.textContent = song.version ? "(" + song.version + ")" : "";

      document.getElementById("song-search-mode").hidden = true;
      document.getElementById("song-manual-mode").hidden = true;
      document.getElementById("song-selected").hidden = false;

      document.getElementById("manual-song-title").removeAttribute("name");
      document.getElementById("manual-song-artist").removeAttribute("name");
    };

    window.clearSongSelection = function() {
      clearHiddenSongFields();
      document.getElementById("song-selected").hidden = true;
      document.getElementById("song-search-mode").hidden = false;
      songSearchInput.value = "";
      songResults.innerHTML = "";
      songSearchInput.focus();
    };

    function clearHiddenSongFields() {
      document.getElementById("hidden-song-title").value = "";
      document.getElementById("hidden-song-artist").value = "";
      document.getElementById("hidden-song-version").value = "";
      document.getElementById("hidden-song-external-id").value = "";
    }

    function escapeHtml(text) {
      const d = document.createElement("div");
      d.textContent = text;
      return d.innerHTML;
    }

    function escapeAttr(text) {
      return text.replace(/&/g, "&amp;").replace(/"/g, "&quot;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
    }

    // Set initial state: search mode active, manual fields have no name
    document.getElementById("manual-song-title").removeAttribute("name");
    document.getElementById("manual-song-artist").removeAttribute("name");
  })();
</script>
