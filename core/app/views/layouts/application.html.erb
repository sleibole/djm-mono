<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "DJMagic.io" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="DJMagic.io">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag "pico.classless.min", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <header>
      <nav>
        <ul>
          <li><strong><a href="/">DJMagic.io</a></strong></li>
        </ul>
        <ul>
          <% if logged_in? %>
            <li><a href="<%= catalogs_path %>">Catalogs</a></li>
            <li><a href="<%= account_path %>">Account</a></li>
            <li><%= button_to "Log Out", logout_path, method: :delete %></li>
          <% else %>
            <li><a href="<%= login_path %>">Sign In</a></li>
            <li><a href="<%= signup_path %>" role="button">Get Started</a></li>
          <% end %>
        </ul>
      </nav>
    </header>

    <main>
      <% if notice %><p role="alert" class="flash notice"><%= notice %></p><% end %>
      <% if alert %><p role="alert" class="flash alert"><%= alert %></p><% end %>
      <%= yield %>
    </main>

    <footer>
      <small>DJMagic.io</small>
    </footer>
  </body>
</html>
