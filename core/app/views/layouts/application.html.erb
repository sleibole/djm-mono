<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "DJMagic.io" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="DJMagic.io">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/favicon.ico" type="image/x-icon">
    <link rel="icon" href="/icon.png" type="image/png" sizes="32x32">
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" sizes="180x180">

    <%= stylesheet_link_tag "pico.min", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <script src="https://kit.fontawesome.com/cade1152b0.js" crossorigin="anonymous" defer></script>
    <script src="https://challenges.cloudflare.com/turnstile/v0/api.js" async defer></script>
    <link rel="stylesheet" href="https://cdn-uicons.flaticon.com/uicons-regular-rounded/css/uicons-regular-rounded.css">
    <%= javascript_importmap_tags %>
    <script>
      (function() {
        var t = localStorage.getItem("theme");
        if (t === "light" || t === "dark") document.documentElement.setAttribute("data-theme", t);
      })();

      function copyLink(button, sourceId) {
        var text = document.getElementById(sourceId).textContent;
        navigator.clipboard.writeText(text).then(function() {
          var original = button.innerHTML;
          button.innerHTML = '<i class="fa-solid fa-check"></i> Copied!';
          setTimeout(function() { button.innerHTML = original; }, 2000);
        });
      }

      function printShareDialog(dialogEl) {
        var area = document.getElementById("print-area");
        if (!area) {
          area = document.createElement("div");
          area.id = "print-area";
          area.style.display = "none";
          document.body.appendChild(area);
        }
        var body = dialogEl.querySelector(".share-dialog-body");
        area.innerHTML = body ? body.innerHTML : "";
        window.print();
      }
    </script>
  </head>

  <body>
    <header class="container">
      <nav>
        <ul>
          <li>
            <%= link_to root_path, class: "site-logo", title: "Home" do %>
              <%= image_tag "brand_icons/dark/dark_64.png", alt: "DJMagic.io", class: "brand-icon" %>
              <span class="brand-text">DJMagic.io</span>
            <% end %>
          </li>
        </ul>
        <button class="nav-toggle" aria-label="Menu" aria-expanded="false" onclick="this.setAttribute('aria-expanded', this.getAttribute('aria-expanded') === 'false' ? 'true' : 'false'); document.getElementById('nav-menu').classList.toggle('open')">
          <span class="hamburger"></span>
        </button>
        <ul id="nav-menu" class="nav-menu">
          <% if logged_in? %>
            <li><a href="<%= shows_path %>">Shows</a></li>
            <li><a href="<%= catalogs_path %>">Catalogs</a></li>
            <li><a href="<%= account_path %>">Account</a></li>
            <li><%= button_to "Log Out", logout_path, method: :delete %></li>
          <% else %>
            <li><a href="<%= login_path %>">Sign In</a></li>
            <li><a href="<%= signup_path %>" role="button">Get Started</a></li>
          <% end %>
        </ul>
      </nav>
    </header>

    <main class="container">
      <% if notice %><p role="alert" class="flash notice"><%= notice %></p><% end %>
      <% if alert %><p role="alert" class="flash alert"><%= alert %></p><% end %>
      <%= yield %>
    </main>

    <footer class="container">
      <small>DJMagic.io</small>
    </footer>
  </body>
</html>
