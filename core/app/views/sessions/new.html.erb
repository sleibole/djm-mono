<h1>Sign in</h1>

<section>
  <p>Enter your email and we'll send you a link to sign in.</p>

  <%= form_with url: magic_links_path do |f| %>
    <label for="magic_email">Email</label>
    <%= f.email_field :email, id: "magic_email", placeholder: "you@example.com", required: true, autofocus: true %>
    <%= f.submit "Send Magic Link" %>
  <% end %>
</section>

<section>
  <details class="section-panel">
    <summary>Sign in with password instead</summary>

    <%= form_with url: login_path do |f| %>
      <label for="password_email">Email</label>
      <%= f.email_field :email, id: "password_email", placeholder: "you@example.com", required: true %>

      <label for="password">Password</label>
      <%= f.password_field :password, id: "password", required: true %>

      <%= f.submit "Sign In" %>
    <% end %>
  </details>
</section>

<p>Don't have an account? <a href="<%= signup_path %>">Sign up</a>.</p>
