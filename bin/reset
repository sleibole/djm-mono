#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "$0")/.." && pwd)"

echo "This will destroy ALL databases for both apps and recreate them from scratch."
read -p "Are you sure? [y/N] " confirm
if [[ ! "$confirm" =~ ^[Yy]$ ]]; then
  echo "Aborted."
  exit 0
fi

# Stop running servers first
"$ROOT_DIR/bin/stop"

echo ""
echo "== Removing core databases =="
find "$ROOT_DIR/core/storage" -name "*.sqlite3*" -delete -print

echo ""
echo "== Removing songs databases =="
find "$ROOT_DIR/songs/storage" -name "*.sqlite3*" -delete -print

echo ""
echo "== Removing songs catalog DBs =="
if [ -d "$ROOT_DIR/songs/storage/catalog_dbs" ]; then
  rm -rf "$ROOT_DIR/songs/storage/catalog_dbs"
  mkdir -p "$ROOT_DIR/songs/storage/catalog_dbs"
  echo "  Cleared catalog_dbs/"
fi

echo ""
echo "== Removing Active Storage uploads =="
for dir in "$ROOT_DIR/songs/storage/oc" "$ROOT_DIR/songs/storage/*/"; do
  if [ -d "$dir" ] && [ "$(basename "$dir")" != "catalog_dbs" ]; then
    rm -rf "$dir"
    echo "  Removed $dir"
  fi
done

echo ""
echo "== Recreating core databases =="
cd "$ROOT_DIR/core" && bin/rails db:prepare

echo ""
echo "== Recreating songs databases =="
cd "$ROOT_DIR/songs" && bin/rails db:prepare

echo ""
echo "Done! Databases have been reset. Run bin/dev to start."
